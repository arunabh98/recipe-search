# Get your key from https://dashboard.exa.ai (API Keys page)
EXA_API_KEY=your-exa-api-key-here

# Optional overrides (defaults shown):
# EXA_BASE_URL=https://api.exa.ai
# EXA_TIMEOUT_SECONDS=20

# Anthropic API key for recipe-candidate evaluation — https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional evaluation overrides (defaults shown):
# EVALUATION_MODEL=claude-opus-4-8
# EVALUATION_EFFORT=medium
# EVALUATION_TIMEOUT_SECONDS=120

# Public-demo protections. All inactive until DEMO_MODE=true, which turns on
# request limits and hides /docs. Also set spend caps in the Anthropic and
# Exa dashboards before sharing publicly.
# DEMO_MODE=true
# DAILY_REQUEST_BUDGET=120        # global cap across all visitors, resets at UTC midnight
# IP_REQUESTS_PER_HOUR=4
# IP_REQUESTS_PER_DAY=8
# TRUST_PROXY_HEADERS=false       # true only when deployed behind a proxy you control

# Optional usage stats, all off unless set. USAGE_DB_PATH records one SQLite
# row per request (salted-hash IP, query text, outcome, timing); STATS_TOKEN
# enables GET /stats. Generate secrets with: openssl rand -hex 24
# USAGE_DB_PATH=/data/usage.db    # on Railway, mount a volume at /data first
# USAGE_SALT=change-me            # keeps visitor hashes stable across restarts
# STATS_TOKEN=change-me
